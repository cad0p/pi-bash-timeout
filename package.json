{
  "name": "@cad0p/pi-bash-timeout",
  "version": "0.1.0",
  "description": "Wraps pi's built-in bash tool with a 120s default timeout — preserves the stock renderer and delegates execution to the built-in implementation.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "bash",
    "timeout",
    "safety",
    "tool-wrapper"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cad0p/pi-bash-timeout.git"
  },
  "homepage": "https://github.com/cad0p/pi-bash-timeout#readme",
  "bugs": {
    "url": "https://github.com/cad0p/pi-bash-timeout/issues"
  },
  "files": [
    "extensions/**/*.ts",
    "!extensions/**/*.test.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "extensions/pi-bash-timeout"
    ]
  },
  "scripts": {
    "lint": "biome check extensions/",
    "lint:fix": "biome check --write extensions/",
    "typecheck": "tsc --noEmit",
    "test": "node --test extensions/**/*.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "typebox": "^1.0.0"
  },
  "license": "MIT"
}
